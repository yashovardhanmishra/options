# Copy to `.env` (or `.env.local`) for local dev, and set the same values as
# build args when deploying. Leave BOTH unset to run with NO login (the app works
# exactly as before).
#
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: override the backend URL (default: same-origin in production)
# VITE_API_BASE=
